PORT=3003
DB_PATH=./chicken-scratch.db
AUTH_THRESHOLD=50
NODE_ENV=development

# Encryption key for biometric data at rest (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ENCRYPTION_KEY=

# Sentry error tracking. When set, backend errors + unhandled exceptions
# are reported to Sentry with aggressive data scrubbing (biometric payloads,
# API keys, SDK tokens, attestation tokens are redacted before send).
# Leave unset to disable in local/dev.
# SENTRY_DSN=
