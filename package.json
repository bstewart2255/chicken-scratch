{
  "name": "chicken-scratch-v2",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/shared",
    "packages/backend",
    "packages/frontend",
    "packages/sdk"
  ],
  "scripts": {
    "dev": "concurrently -n backend,frontend -c blue,green \"npm run dev -w packages/backend\" \"npm run dev -w packages/frontend\"",
    "build": "npm run build -w packages/shared && npm run build -w packages/backend && npm run build -w packages/frontend",
    "test": "vitest run",
    "test:unit": "vitest run packages/backend/src/__tests__/crypto.test.ts",
    "test:integration": "vitest run packages/backend/src/__tests__/admin.routes.test.ts packages/backend/src/__tests__/tenant-api.test.ts packages/backend/src/__tests__/admin-auth.test.ts",
    "db:migrate": "npm run db:migrate -w packages/backend",
    "lint": "eslint packages/*/src/**/*.ts packages/*/src/**/*.tsx"
  },
  "devDependencies": {
    "@types/supertest": "^7.2.0",
    "concurrently": "^8.2.2",
    "pg-mem": "^3.0.14",
    "supertest": "^7.2.2",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
