{
  "name": "@chicken-scratch/sdk",
  "version": "0.1.0",
  "description": "Drop-in JavaScript SDK for chickenScratch biometric authentication",
  "type": "module",
  "main": "./dist/chicken-scratch.js",
  "module": "./dist/chicken-scratch.mjs",
  "types": "./dist/index.d.ts",
