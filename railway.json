{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build -w packages/shared && npm run build -w packages/backend"
  },
  "deploy": {
    "startCommand": "npm run start -w packages/backend",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
